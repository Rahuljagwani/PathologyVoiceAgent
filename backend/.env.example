# Backend environment variables for Pathology Lab Voice Agent

# Environment
ENVIRONMENT=development
BASE_URL=http://localhost:8000

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Bolna AI (optional webhook secret)
BOLNA_WEBHOOK_SECRET=

# Auth
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
# Comma-separated list of allowed frontend origins.
# Example for local + production:
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-frontend-domain.com
CORS_ALLOW_ORIGINS=
